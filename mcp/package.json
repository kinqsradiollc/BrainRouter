{
  "name": "@brainrouter/mcp-server",
  "version": "0.1.0",
  "description": "BrainRouter MCP Server — exposes skills, docs, and personas as MCP tools to minimize agent context size.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "brainrouter-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "dev:http": "tsx watch src/index.ts -- --http --port 3747",
    "start": "node dist/index.js",
    "start:http": "node dist/index.js --http --port 3747",
    "test": "vitest run",
    "setup:mcp": "node scripts/setup-mcp.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.11.0",
    "dotenv": "^16.4.5",
    "express": "^5.2.1",
    "glob": "^11.0.0",
    "gray-matter": "^4.0.3",
    "sqlite-vec": "^0.1.9",
    "zod": "^3.22.4"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  }
}

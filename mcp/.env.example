# BrainRouter Memory Engine Configuration

# 1. LLM API Key (Required for extraction)
# For local models, this might be "ollama", "lm-studio", or any string.
BRAINROUTER_LLM_API_KEY=your_api_key_here

# 2. LLM Endpoint (Optional, defaults to OpenAI)
# Example for Ollama: http://localhost:11434/v1/chat/completions
# Example for LM Studio: http://localhost:1234/v1/chat/completions
BRAINROUTER_LLM_ENDPOINT=https://api.openai.com/v1/chat/completions

# 3. LLM Model Name (Optional, defaults to gpt-4o-mini)
# Example for local: llama3, mistral, qwen2:7b
BRAINROUTER_LLM_MODEL=gpt-4o-mini

# 4. Memory Database Path (Optional, defaults to ~/.brainrouter/memory.db)
# BRAINROUTER_MEMORY_DB=./memory.db

# ==========================================
# Phase 2: Embedding Service Configuration
# ==========================================

# 1. Embedding API Key (Optional)
# If not provided, it falls back to BRAINROUTER_LLM_API_KEY.
# If neither is provided, vector search is gracefully disabled.
# BRAINROUTER_EMBEDDING_API_KEY=

# 2. Embedding Endpoint (Optional)
# Example for Ollama: http://localhost:11434/v1/embeddings
# BRAINROUTER_EMBEDDING_ENDPOINT=https://api.openai.com/v1/embeddings

# 3. Embedding Model (Optional, defaults to text-embedding-3-small)
# Example for local: nomic-embed-text
# BRAINROUTER_EMBEDDING_MODEL=text-embedding-3-small

# 4. Embedding Dimensions (Optional, defaults to 1536)
# IMPORTANT: If you change this later, the vector table will be rebuilt.
# Example for nomic-embed-text: 768
# BRAINROUTER_EMBEDDING_DIMENSIONS=1536

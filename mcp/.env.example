# BrainRouter MCP environment
#
# Copy this file to mcp/.env and run MCP commands from the mcp/ directory
# when you want dotenv/config to load it automatically.

# ==========================================
# Storage
# ==========================================

# SQLite database path. Defaults to ~/.brainrouter/memory.db.
# Use an absolute or repo-local path for isolated test runs.
# BRAINROUTER_MEMORY_DB=/Users/you/.brainrouter/memory.db

# Optional workspace root when --root is omitted.
# BRAINROUTER_LOCAL_ROOT=/path/to/your/project

# ==========================================
# Auth and users
# ==========================================

# Initial admin user values used when the database is empty and by scripts/setup-admin.js.
BRAINROUTER_DEFAULT_ADMIN_USER_ID=admin
BRAINROUTER_ADMIN_EMAIL=admin@example.com
BRAINROUTER_ADMIN_PASSWORD=change_me_before_use

# JWT secret for dashboard sessions.
# If omitted, the server generates a random secret and sessions do not survive restarts.
# Generate one with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BRAINROUTER_JWT_SECRET=replace_with_a_long_random_secret

# JWT expiry in seconds. Default: 86400.
# BRAINROUTER_JWT_EXPIRES_SECS=86400

# API key used by stdio MCP clients. Usually set in the MCP client config,
# not in this file. Generate/reset it with: npm run setup:admin -- --reset --userId admin
# BRAINROUTER_API_KEY=br_your_api_key

# Legacy stdio fallback user id if no authenticated user mapping is available.
# Normal usage should rely on BRAINROUTER_API_KEY instead.
# BRAINROUTER_USER_ID=default

# ==========================================
# LLM extraction and synthesis
# ==========================================

# Required for L1 extraction, contradiction detection, graph extraction, L2 scenes,
# and L3 persona synthesis.
BRAINROUTER_LLM_API_KEY=your_api_key_here

# OpenAI-compatible chat-completions endpoint.
# Examples:
# - OpenAI: https://api.openai.com/v1/chat/completions
# - Ollama: http://localhost:11434/v1/chat/completions
# - LM Studio: http://localhost:1234/v1/chat/completions
BRAINROUTER_LLM_ENDPOINT=https://api.openai.com/v1/chat/completions

# Default chat model. The code falls back to gpt-4o-mini when unset.
BRAINROUTER_LLM_MODEL=gpt-4o-mini

# Optional model routing.
# Extraction tasks include L1 extraction, contradiction detection, and graph extraction.
# Synthesis tasks include L2 scenes and L3 persona.
# BRAINROUTER_EXTRACTION_MODEL=gpt-4o-mini
# BRAINROUTER_SYNTHESIS_MODEL=gpt-4o

# ==========================================
# Embeddings and vector search
# ==========================================

# If BRAINROUTER_EMBEDDING_API_KEY is omitted, the server falls back to
# BRAINROUTER_LLM_API_KEY. If no key is available, vector search is disabled and
# recall uses keyword/file-path search.
# BRAINROUTER_EMBEDDING_API_KEY=
BRAINROUTER_EMBEDDING_ENDPOINT=https://api.openai.com/v1/embeddings
BRAINROUTER_EMBEDDING_MODEL=text-embedding-3-small
BRAINROUTER_EMBEDDING_DIMENSIONS=1536

# ==========================================
# Optional reranking
# ==========================================

# Reranking is disabled unless an API key is present.
# BRAINROUTER_RERANKER_API_KEY=
# BRAINROUTER_RERANKER_ENDPOINT=https://api.cohere.com/v1/rerank
# BRAINROUTER_RERANKER_MODEL=rerank-english-v3.0
# BRAINROUTER_RERANKER_TOP_N=5

# ==========================================
# Distillation scheduling and cache
# ==========================================

# Run L2 scene distillation after this many new L1 records. Default: 10.
# BRAINROUTER_L2_TRIGGER_N=10

# Run L3 persona distillation after this many new L1 records. Default: 50.
# BRAINROUTER_L3_TRIGGER_N=50

# Maximum L2 scene count used by scene-management logic. Default: 20.
# BRAINROUTER_L2_MAX_SCENES=20

# Persona cache TTL in milliseconds. Default: 3600000.
# BRAINROUTER_PERSONA_CACHE_TTL_MS=3600000

# ==========================================
# Graph and contradiction background work
# ==========================================

# Set false to disable GraphRAG extraction. Default: enabled.
# BRAINROUTER_GRAPH_ENABLED=true

# Background LLM timeouts in milliseconds.
# BRAINROUTER_GRAPH_TIMEOUT_MS=120000
# BRAINROUTER_CONTRADICTION_TIMEOUT_MS=60000

# ==========================================
# Skill activation and pre-warming
# ==========================================

# Skill activation scoring defaults are defined in mcp/src/memory/pipeline/skill-prewarm.ts.
# BRAINROUTER_SKILL_HALF_LIFE_MINUTES=10
# BRAINROUTER_SKILL_MIN_TURN_DECAY=0.05
# BRAINROUTER_SKILL_PREWARM_THRESHOLD=0.3
# BRAINROUTER_SKILL_SPIKE_AMOUNT=1.0
# BRAINROUTER_SKILL_MAX_POTENTIAL=4.0

# Recall-time skill-hint pre-warming is opt-in.
# BRAINROUTER_PREWARM_ENABLED=false
# BRAINROUTER_PREWARM_MIN_HITS=3
# BRAINROUTER_PREWARM_WINDOW=10

# ==========================================
# ACE citation feedback
# ==========================================

# Memories recalled this many times without citation are auto-archived.
# Set 0 to disable. Default: 10.
# BRAINROUTER_ACE_ARCHIVE_THRESHOLD=10

# ==========================================
# Extraction backlog sweeper
# ==========================================

# Disable the autonomous extraction sweeper.
# BRAINROUTER_DISABLE_EXTRACTION_SWEEPER=false

# Sweeper interval. Default: 300000.
# BRAINROUTER_EXTRACTION_SWEEP_INTERVAL_MS=300000

# Minimum age before unextracted L0 records are retried. Default: 120000.
# BRAINROUTER_EXTRACTION_SWEEP_MIN_AGE_MS=120000

# Maximum extraction failures before a backlog item is ignored. Default: 5.
# BRAINROUTER_EXTRACTION_MAX_FAILURES=5

# ==========================================
# Dashboard
# ==========================================

# This is read by the Next.js dashboard in web/, not by the MCP server.
# NEXT_PUBLIC_API_URL=http://localhost:3747

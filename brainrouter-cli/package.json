{
  "name": "@brainrouter/cli",
  "version": "0.3.4",
  "description": "Memory-native terminal coding agent. Talks to the BrainRouter MCP cognitive engine for recall, skills, capture, persona, focus scenes, and contradiction tracking.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "brainrouter": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    ".env.example"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "npm run build && node --test \"dist/**/*.test.js\"",
    "prepack": "npm run build && find dist -name '*.test.*' -delete"
  },
  "dependencies": {
    "@brainrouter/sdk": "^0.3.4",
    "@brainrouter/types": "^0.3.4",
    "@modelcontextprotocol/sdk": "^1.11.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "inquirer": "^9.3.2",
    "marked": "^12.0.1",
    "marked-terminal": "^7.0.0",
    "ora": "^8.0.1"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.7",
    "@types/marked": "^4.0.8",
    "@types/node": "^22.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "keywords": [
    "ai",
    "agent",
    "cli",
    "mcp",
    "model-context-protocol",
    "memory",
    "llm",
    "coding-agent",
    "terminal",
    "brainrouter"
  ],
  "license": "MIT",
  "author": "BrainRouter contributors",
  "homepage": "https://github.com/kinqsradiollc/BrainRouter#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kinqsradiollc/BrainRouter.git",
    "directory": "brainrouter-cli"
  },
  "bugs": {
    "url": "https://github.com/kinqsradiollc/BrainRouter/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}

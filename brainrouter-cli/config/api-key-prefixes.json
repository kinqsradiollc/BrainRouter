    { "prefix": "sk-proj-", "vendor": "OpenAI (scoped project key)" },
    { "prefix": "dsk-", "vendor": "DeepSeek" }
  ],
  "foreignModelPrefixes": [
    { "prefix": "anthropic/", "vendor": "Anthropic" },
    { "prefix": "google/", "vendor": "Google" },
    { "prefix": "meta/", "vendor": "Meta" },
    { "prefix": "mistralai/", "vendor": "Mistral" },
    { "prefix": "qwen/", "vendor": "Qwen" },
    { "prefix": "deepseek/", "vendor": "DeepSeek" }
  ]
